sprite Stage {
    costume cat "cat.svg";
}

sprite cat {
    costume cat "cat.svg";

    func main(){
        list keys = [];
        list values = [];
        list printList = [];
        keys.add("erm");
        values.add(10);
        printList.add(values[keys.index("erm")]);
        printList.delete(printList.length);
        printList.insert("hi", 1);
    }
}
sprite Stage {
    costume cat "cat.svg";
}

sprite cat {
    costume cat "cat.svg";

    require "static.scratch";

    func myFunction(thing, what){
        return thing + what;
    }
    
    func main(){
        ptr huh << myFunction(10, 20);
        print(huh);
        huh << myFunction(100, 1);
        print(huh);
    }
}
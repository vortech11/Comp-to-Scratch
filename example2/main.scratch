sprite Stage {
    costume cat "cat.svg";
}

sprite cat {
    costume cat "cat.svg";

    require "static.scratch";
    
    func main(){
        setxy(-100000, 0);
        var maxDistance = 1000;
        for (ptr i = 1; i < maxDistance; i *= 2){
            move(i);
            sleep(1 / ((i / 2) + 1));
            print(i);
        }
    }
}